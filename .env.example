# ============================================================
# EventOps — Variables de entorno
# Copia este archivo como .env y rellena los valores reales.
# NUNCA subas el archivo .env al repositorio.
# ============================================================

# Base44 BaaS — ID de la aplicación (obligatorio)
VITE_BASE44_APP_ID=your_app_id_here

# Base44 — versión de funciones Deno desplegadas (opcional)
VITE_BASE44_FUNCTIONS_VERSION=

# Base44 — URL base de la app para el proxy de desarrollo (opcional)
VITE_BASE44_APP_BASE_URL=

# Activa la compatibilidad con imports legacy del SDK de Base44
# Poner a "true" solo si el código importa desde @/integrations, @/entities, etc.
BASE44_LEGACY_SDK_IMPORTS=false
